<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Digital Studio</title>
  <meta name="description" content="Production vidéo & Stratégie Digitale">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #000000;
      --text: #ffffff;
      --text-light: #999999;
      --accent: #8b5cf6;
      --transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    [data-theme="light"] {
      --bg: #ffffff;
      --text: #000000;
      --text-light: #666666;
      --accent: #8b5cf6;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Poppins', system-ui, sans-serif;
      line-height: 1.7;
    }

    body {
      transition: background var(--transition);
    }

    body.modal-open {
      overflow: hidden;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button {
      font-family: 'Poppins', system-ui, sans-serif;
      cursor: pointer;
      border: none;
      background: none;
      color: inherit;
    }

    input, textarea, select {
      font-family: 'Poppins', system-ui, sans-serif;
    }

    /* === HEADER === */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      transition: all var(--transition);
    }

    [data-theme="light"] header {
      border-bottom-color: rgba(0, 0, 0, 0.08);
    }

    .header-content {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      display: flex;
      align-items: center;
      height: 40px;
      text-decoration: none;
      transition: all 0.3s ease;
    }

    .logo img {
      height: 100%;
      width: auto;
      max-width: 120px;
      object-fit: contain;
    }

    .logo:hover {
      opacity: 0.8;
    }

    nav {
      display: flex;
      gap: 0;
    }

    nav a {
      display: inline-block;
      padding: 8px 16px;
      font-size: 13px;
      color: var(--text-light);
      transition: all var(--transition);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-weight: 500;
      position: relative;
    }

    nav a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 16px;
      right: 16px;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transform-origin: center;
      transition: transform var(--transition);
    }

    nav a:hover {
      color: var(--text);
    }

    nav a:hover::after {
      transform: scaleX(1);
    }

    .header-controls {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .theme-btn, .menu-btn, .lang-btn {
      font-size: 14px;
      opacity: 0.5;
      transition: opacity var(--transition);
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .theme-btn svg {
      stroke: currentColor;
      color: var(--text);
      transition: transform var(--transition);
    }

    .theme-btn:hover {
      opacity: 1;
    }

    .theme-btn:hover svg {
      transform: rotate(20deg);
    }

    .lang-btn {
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .lang-btn:hover {
      opacity: 1;
    }

    .menu-btn {
      display: none;
      font-size: 20px;
    }

    .theme-btn:hover, .menu-btn:hover, .lang-btn:hover {
      opacity: 1;
    }

    /* === MAIN CONTAINER === */
    main {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 40px;
    }

    /* === HERO SECTION === */
    .hero {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding-top: 80px;
    }

    .hero h1 {
      font-size: clamp(48px, 8vw, 72px);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 32px;
      max-width: 900px;
      letter-spacing: -1px;
    }

    .hero p {
      font-size: 18px;
      color: var(--text-light);
      max-width: 600px;
      margin-bottom: 48px;
      line-height: 1.8;
    }

    .cta {
      display: inline-block;
      padding: 14px 40px;
      background: var(--accent);
      color: white;
      border-radius: 4px;
      font-weight: 600;
      font-size: 14px;
      transition: all var(--transition);
    }

    .cta:hover {
      background: var(--accent);
      opacity: 0.8;
      transform: translateY(-2px);
    }

    @media (max-width: 1024px) {
      .hero {
        min-height: 100vh;
      }
    }

    @media (max-width: 768px) {
      .hero {
        padding-top: 100px;
      }

      .hero h1 {
        margin-bottom: 24px;
      }

      .hero p {
        margin-bottom: 32px;
      }

      [style*="display: flex; gap: 16px"] {
        flex-direction: column;
      }

      [style*="display: flex; gap: 16px"] button {
        width: 100%;
      }
    }

    /* === SECTIONS === */
    section {
      padding: 120px 0;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    [data-theme="light"] section {
      border-top-color: rgba(0, 0, 0, 0.1);
    }

    section:first-of-type {
      border-top: none;
    }

    h2 {
      font-size: 48px;
      font-weight: 700;
      margin-bottom: 60px;
      letter-spacing: -1px;
    }

    /* === ABOUT === */
    #about p {
      font-size: 16px;
      color: var(--text-light);
      line-height: 1.9;
      max-width: 800px;
      margin-bottom: 24px;
    }

    #about p:first-of-type {
      font-size: 18px;
      font-weight: 500;
      color: var(--text);
      margin-bottom: 32px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 60px;
      margin-top: 80px;
    }

    .stat {
      display: flex;
      flex-direction: column;
      text-align: center;
    }

    .stat-number {
      font-size: 48px;
      font-weight: 800;
      color: var(--accent);
      margin-bottom: 12px;
      line-height: 1;
    }

    .stat-label {
      font-size: 13px;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    @media (max-width: 768px) {
      .stats {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .stat-number {
        font-size: 36px;
      }
    }

    /* === SERVICES === */
    .services-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
    }

    .service {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding: 40px;
      border: 2px solid rgba(255, 255, 255, 0.08);
      border-radius: 8px;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, rgba(139, 92, 246, 0.02) 100%);
      transition: all var(--transition);
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .service::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, var(--accent) 0%, transparent 100%);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .service:hover::before {
      transform: scaleX(1);
    }

    [data-theme="light"] .service {
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.02) 0%, rgba(139, 92, 246, 0.03) 100%);
      border-color: rgba(0, 0, 0, 0.08);
    }

    .service:hover {
      border-color: var(--accent);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(139, 92, 246, 0.06) 100%);
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(139, 92, 246, 0.1);
    }

    [data-theme="light"] .service:hover {
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.04) 0%, rgba(139, 92, 246, 0.06) 100%);
      box-shadow: 0 20px 40px rgba(139, 92, 246, 0.08);
    }

    .service-number {
      font-size: 56px;
      font-weight: 900;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 2px;
      line-height: 1;
      opacity: 0.3;
      position: relative;
      margin-bottom: 8px;
    }

    .service:hover .service-number {
      opacity: 0.6;
      transform: scale(1.05);
    }

    .service-content {
      position: relative;
      z-index: 1;
    }

    .service-content h3 {
      font-size: 20px;
      font-weight: 700;
      margin: 0;
      margin-bottom: 16px;
      color: var(--text);
      letter-spacing: 0.5px;
    }

    .service-content p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.8;
      margin: 0;
    }

    .service::after {
      content: '→';
      position: absolute;
      bottom: 24px;
      right: 24px;
      font-size: 24px;
      color: var(--accent);
      opacity: 0;
      transform: translateX(-8px);
      transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .service:hover::after {
      opacity: 1;
      transform: translateX(0);
    }

    /* === PROJECTS === */
    .projects-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 40px;
    }

    .project {
      aspect-ratio: 1;
      background: rgba(255, 255, 255, 0.05);
      border-radius: 8px;
      overflow: hidden;
      position: relative;
      cursor: pointer;
      transition: all var(--transition);
      border: 2px solid rgba(255, 255, 255, 0.08);
    }

    [data-theme="light"] .project {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.08);
    }

    .project::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, var(--accent) 0%, transparent 100%);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      z-index: 2;
    }

    .project:hover::before {
      transform: scaleX(1);
    }

    .project img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s ease-out;
    }

    .project:hover img {
      transform: scale(1.08);
    }

    .project:hover {
      border-color: var(--accent);
      box-shadow: 0 20px 40px rgba(255, 85, 0, 0.1);
      transform: translateY(-8px);
    }

    [data-theme="light"] .project:hover {
      box-shadow: 0 20px 40px rgba(255, 85, 0, 0.08);
    }

    .project-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0) 40%, rgba(0, 0, 0, 0.5) 70%, rgba(0, 0, 0, 0.9) 100%);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 32px;
      opacity: 0;
      transition: opacity var(--transition);
    }

    .project:hover .project-overlay {
      opacity: 1;
    }

    .project-overlay-content {
      position: relative;
    }

    .project-overlay h3 {
      font-size: 20px;
      font-weight: 700;
      color: white;
      margin-bottom: 8px;
      letter-spacing: 0.5px;
    }

    .project-overlay p {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.8);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .project::after {
      content: '→';
      position: absolute;
      bottom: 24px;
      right: 24px;
      font-size: 24px;
      color: var(--accent);
      opacity: 0;
      transform: translateX(-8px);
      transition: all 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      z-index: 3;
    }

    .project:hover::after {
      opacity: 1;
      transform: translateX(0);
    }

    /* === CONTACT === */
    .contact-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-group label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-light);
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      padding: 12px 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 4px;
      background: rgba(255, 255, 255, 0.02);
      color: var(--text);
      font-size: 14px;
      transition: all var(--transition);
    }

    [data-theme="light"] .form-group input,
    [data-theme="light"] .form-group textarea,
    [data-theme="light"] .form-group select {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--accent);
      background: rgba(255, 255, 255, 0.05);
    }

    [data-theme="light"] .form-group input:focus,
    [data-theme="light"] .form-group textarea:focus,
    [data-theme="light"] .form-group select:focus {
      background: rgba(0, 0, 0, 0.05);
    }

    .form-group textarea {
      resize: vertical;
      min-height: 120px;
    }

    .contact-info {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .contact-info h3 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 40px;
    }

    .info-item {
      margin-bottom: 32px;
    }

    .info-item label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-light);
      display: block;
      margin-bottom: 8px;
    }

    .info-item p {
      font-size: 15px;
      color: var(--text);
    }

    .info-item a {
      color: var(--accent);
      transition: opacity var(--transition);
    }

    .info-item a:hover {
      opacity: 0.8;
    }

    /* === FOOTER === */
    footer {
      padding: 80px 0 40px;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      color: var(--text-light);
      font-size: 13px;
    }

    [data-theme="light"] footer {
      border-top-color: rgba(0, 0, 0, 0.1);
    }

    footer p {
      text-align: center;
    }

    /* === RESPONSIVE === */
    @media (max-width: 768px) {
      .header-content {
        padding: 16px 24px;
      }

      nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        flex-direction: column;
        padding: 24px;
        gap: 0;
      }

      nav.mobile-open {
        display: flex;
      }

      nav.mobile-open a {
        display: block;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        margin: 0;
      }

      nav.mobile-open a:last-child {
        border-bottom: none;
      }

      nav.mobile-open a::after {
        display: none;
      }

      .menu-btn {
        display: block;
      }

      main {
        padding: 0 24px;
      }

      .hero {
        height: auto;
        min-height: 80vh;
        padding-top: 60px;
        padding-bottom: 60px;
      }

      .hero h1 {
        font-size: 36px;
        margin-bottom: 24px;
      }

      .hero p {
        font-size: 16px;
        margin-bottom: 32px;
      }

      section {
        padding: 80px 0;
      }

      h2 {
        font-size: 32px;
        margin-bottom: 40px;
      }

      .contact-wrapper {
        grid-template-columns: 1fr;
        gap: 60px;
      }

      .projects-list {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .project {
        aspect-ratio: 16/9;
      }

      .stats {
        grid-template-columns: 1fr 1fr;
      }

      .services-list {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }

      .service {
        flex-direction: column;
        gap: 16px;
      }
    }

    @media (max-width: 480px) {
      .header-content {
        padding: 12px 16px;
      }

      .logo {
        font-size: 12px;
      }

      main {
        padding: 0 16px;
      }

      .hero h1 {
        font-size: 28px;
        margin-bottom: 16px;
      }

      .hero p {
        font-size: 14px;
      }

      section {
        padding: 60px 0;
      }

      h2 {
        font-size: 24px;
        margin-bottom: 32px;
      }

      .stats {
        grid-template-columns: 1fr;
        gap: 40px;
      }

      .services-list {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .service {
        padding: 24px;
      }

      .service-content p {
        font-size: 14px;
      }

      nav {
        padding: 16px;
      }

      nav.mobile-open a {
        padding: 10px 0;
      }
    }

    /* === ACCESSIBILITY === */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* === SERVICE MODAL === */
    .service-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(4px);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
      animation: fadeIn 0.3s ease;
    }

    .service-modal.active {
      display: flex;
    }

    .service-modal-content {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 48px;
      max-width: 700px;
      width: 100%;
      max-height: 80vh;
      overflow-y: auto;
      position: relative;
      animation: slideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    [data-theme="light"] .service-modal-content {
      background: #f5f5f5;
      border-color: rgba(0, 0, 0, 0.1);
    }

    .service-modal-close {
      position: absolute;
      top: 24px;
      right: 24px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      font-size: 20px;
      color: var(--text);
      cursor: pointer;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      padding: 0;
    }

    [data-theme="light"] .service-modal-close {
      background: rgba(0, 0, 0, 0.05);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .service-modal-close:hover {
      background: var(--accent);
      border-color: var(--accent);
      transform: scale(1.1);
    }

    .service-modal-close svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
    }

    .service-modal-header {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 32px;
      padding-right: 32px;
    }

    .service-modal-number {
      font-size: 48px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
      text-transform: uppercase;
      min-width: 60px;
    }

    .service-modal-header h2 {
      margin: 0;
      margin-top: 8px;
      font-size: 32px;
      line-height: 1.2;
    }

    .service-modal-description {
      font-size: 16px;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 32px;
    }

    .service-modal-details {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-bottom: 32px;
    }

    .detail-item {
      padding: 20px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }

    [data-theme="light"] .detail-item {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .detail-item strong {
      display: block;
      color: var(--accent);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .detail-item p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.6;
      margin: 0;
    }

    .service-modal-benefits {
      margin-bottom: 32px;
    }

    .service-modal-benefits h3 {
      font-size: 16px;
      font-weight: 600;
      margin: 0 0 16px 0;
      color: var(--text);
    }

    .benefits-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .benefits-list li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      color: var(--text-light);
    }

    .benefits-list li::before {
      content: '✓';
      color: var(--accent);
      font-weight: 800;
      font-size: 16px;
      flex-shrink: 0;
    }

    .service-modal-cta {
      display: flex;
      gap: 12px;
    }

    .service-modal-cta button {
      flex: 1;
      padding: 12px 24px;
      border: none;
      border-radius: 4px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .service-modal-cta .btn-primary {
      background: var(--accent);
      color: white;
    }

    .service-modal-cta .btn-primary:hover {
      opacity: 0.8;
    }

    .service-modal-cta .btn-secondary {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: var(--text);
    }

    .service-modal-cta .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    @media (max-width: 768px) {
      .service-modal-content {
        padding: 32px 24px;
      }

      .service-modal-close {
        top: 16px;
        right: 16px;
      }

      .service-modal-header {
        padding-right: 0;
        margin-bottom: 24px;
      }

      .service-modal-number {
        font-size: 36px;
      }

      .service-modal-header h2 {
        font-size: 24px;
      }

      .service-modal-details {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .service-modal-cta {
        flex-direction: column;
      }
    }

    /* === PROJECT MODAL === */
    .project-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(4px);
      z-index: 1000;
      align-items: center;
      justify-content: center;
      padding: 20px;
      animation: fadeIn 0.3s ease;
    }

    .project-modal.active {
      display: flex;
    }

    .project-modal-content {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      overflow: hidden;
      max-width: 900px;
      width: 100%;
      max-height: 85vh;
      overflow-y: auto;
      position: relative;
      animation: slideUp 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    [data-theme="light"] .project-modal-content {
      background: #f5f5f5;
      border-color: rgba(0, 0, 0, 0.1);
    }

    .project-modal-close {
      position: absolute;
      top: 24px;
      right: 24px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      font-size: 20px;
      color: var(--text);
      cursor: pointer;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all 0.3s ease;
      z-index: 10;
      padding: 0;
    }

    [data-theme="light"] .project-modal-close {
      background: rgba(0, 0, 0, 0.05);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .project-modal-close:hover {
      background: var(--accent);
      border-color: var(--accent);
      transform: scale(1.1);
    }

    .project-modal-close svg {
      width: 20px;
      height: 20px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
    }

    .project-modal-image {
      width: 100%;
      height: 400px;
      object-fit: cover;
    }

    .project-modal-body {
      padding: 48px;
    }

    .project-modal-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 32px;
    }

    .project-modal-header-content h2 {
      margin: 0;
      font-size: 32px;
      line-height: 1.2;
    }

    .project-modal-header-meta {
      text-align: right;
      font-size: 13px;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .project-modal-description {
      font-size: 16px;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 32px;
    }

    .project-modal-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
      margin-bottom: 32px;
    }

    .project-detail-item {
      padding: 24px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 4px;
    }

    [data-theme="light"] .project-detail-item {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .project-detail-item strong {
      display: block;
      color: var(--accent);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }

    .project-detail-item p {
      font-size: 14px;
      color: var(--text-light);
      line-height: 1.6;
      margin: 0;
    }

    .project-modal-section {
      margin-bottom: 32px;
    }

    .project-modal-section h3 {
      font-size: 18px;
      font-weight: 600;
      margin: 0 0 16px 0;
      color: var(--text);
    }

    .project-modal-services {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .project-service-tag {
      display: inline-block;
      padding: 8px 16px;
      background: rgba(139, 92, 246, 0.1);
      border: 1px solid var(--accent);
      border-radius: 4px;
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .project-modal-cta {
      display: flex;
      gap: 12px;
    }

    .project-modal-cta button {
      flex: 1;
      padding: 12px 24px;
      border: none;
      border-radius: 4px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .project-modal-cta a {
      flex: 1;
      padding: 12px 24px;
      border: none;
      border-radius: 4px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
    }

    .project-modal-cta .btn-primary {
      background: var(--accent);
      color: white;
    }

    .project-modal-cta .btn-primary:hover {
      opacity: 0.8;
    }

    .project-modal-cta .btn-secondary {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: var(--text);
    }

    .project-modal-cta .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    @media (max-width: 768px) {
      .project-modal-body {
        padding: 32px 24px;
      }

      .project-modal-image {
        height: 300px;
      }

      .project-modal-header {
        flex-direction: column;
        gap: 16px;
      }

      .project-modal-header-content h2 {
        font-size: 24px;
      }

      .project-modal-header-meta {
        text-align: left;
      }

      .project-modal-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .project-modal-cta {
        flex-direction: column;
      }
    }

    /* === QUIZ MODAL === */
    .quiz-modal {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.7);
      z-index: 1000;
      overflow-y: auto;
      animation: fadeIn 0.3s ease-out;
    }

    .quiz-modal.active {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .quiz-container {
      background: var(--bg);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      padding: 48px;
      max-width: 600px;
      width: 90%;
      position: relative;
      animation: slideUp 0.4s ease-out;
    }

    [data-theme="light"] .quiz-container {
      border-color: rgba(0, 0, 0, 0.1);
    }

    .quiz-close {
      position: absolute;
      top: 24px;
      right: 24px;
      font-size: 24px;
      opacity: 0.5;
      cursor: pointer;
      transition: opacity var(--transition);
      border: none;
      background: none;
      color: var(--text);
    }

    .quiz-close:hover {
      opacity: 1;
    }

    .quiz-title {
      font-size: 28px;
      font-weight: 700;
      margin-bottom: 12px;
      color: var(--text);
    }

    .quiz-subtitle {
      font-size: 14px;
      color: var(--text-light);
      margin-bottom: 32px;
    }

    .quiz-progress {
      height: 3px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 2px;
      margin-bottom: 32px;
      overflow: hidden;
    }

    [data-theme="light"] .quiz-progress {
      background: rgba(0, 0, 0, 0.1);
    }

    .quiz-progress-bar {
      height: 100%;
      background: var(--accent);
      transition: width 0.4s ease-out;
    }

    .quiz-question {
      margin-bottom: 32px;
    }

    .quiz-question h3 {
      font-size: 18px;
      font-weight: 600;
      margin-bottom: 20px;
      color: var(--text);
    }

    .quiz-options {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .quiz-option {
      padding: 14px 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 6px;
      background: rgba(255, 255, 255, 0.02);
      color: var(--text-light);
      cursor: pointer;
      transition: all var(--transition);
      font-size: 14px;
      text-align: left;
    }

    [data-theme="light"] .quiz-option {
      background: rgba(0, 0, 0, 0.02);
      border-color: rgba(0, 0, 0, 0.1);
    }

    .quiz-option:hover {
      border-color: var(--accent);
      background: rgba(255, 255, 255, 0.05);
      color: var(--text);
    }

    [data-theme="light"] .quiz-option:hover {
      background: rgba(0, 0, 0, 0.05);
    }

    .quiz-option.selected {
      border-color: var(--accent);
      background: rgba(255, 85, 0, 0.1);
      color: var(--text);
    }

    .quiz-result {
      text-align: center;
      padding: 32px 0;
    }

    .quiz-result h2 {
      font-size: 24px;
      margin-bottom: 16px;
    }

    .quiz-result-service {
      font-size: 32px;
      font-weight: 800;
      color: var(--accent);
      margin-bottom: 24px;
    }

    .quiz-result-desc {
      font-size: 15px;
      color: var(--text-light);
      line-height: 1.8;
      margin-bottom: 32px;
    }

    .quiz-buttons {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .quiz-btn {
      padding: 12px 32px;
      border-radius: 6px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: all var(--transition);
      border: none;
      font-family: 'Poppins', system-ui, sans-serif;
    }

    .quiz-btn-primary {
      background: var(--accent);
      color: white;
    }

    .quiz-btn-primary:hover {
      opacity: 0.9;
      transform: translateY(-2px);
    }

    .quiz-btn-secondary {
      border: 2px solid var(--accent);
      color: var(--accent);
      background: transparent;
    }

    .quiz-btn-secondary:hover {
      background: rgba(139, 92, 246, 0.1);
    }

    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</head>
<body>
  <skip class="sr-only"><a href="#main">Aller au contenu principal</a></skip>

  <!-- HEADER -->
  <header>
    <div class="header-content">
      <a href="#home" class="logo">
        <img src="https://via.placeholder.com/120x40/8b5cf6/ffffff?text=TDS" alt="The Digital Studio Logo">
      </a>
      <nav id="nav">
        <a href="#about" data-i18n="about">About</a>
        <a href="#services" data-i18n="services">Services</a>
        <a href="#projects" data-i18n="work">Work</a>
        <a href="#contact" data-i18n="getInTouch">Get in touch</a>
      </nav>
      <div class="header-controls">
        <button class="theme-btn" id="theme-toggle" aria-label="Changer le thème">
          <svg id="sun-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          <svg id="moon-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: none;">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
        <button class="lang-btn" id="lang-toggle" aria-label="Toggle language">EN</button>
        <button class="menu-btn" id="menu-toggle" aria-label="Menu">≡</button>
      </div>
    </div>
  </header>

  <!-- MAIN -->
  <main id="main">
    <!-- HERO -->
    <section class="hero" id="home">
      <h1>Créons vos histoires numériques.</h1>
      <p>Nous transformons vos idées en expériences digitales impactantes. Production vidéo, branding et stratégie créative.</p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap;">
        <button class="cta" data-i18n="startProject" onclick="document.getElementById('contact').scrollIntoView({behavior: 'smooth'})">Démarrer un projet</button>
        <button class="cta" data-i18n="discoverNeeds" style="background: transparent; border: 2px solid var(--accent); color: var(--accent);" onclick="openQuiz()">Découvrez ce que votre business a besoin</button>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
      <h2 data-i18n="about">À propos</h2>
      <p>The Digital Studio est un collectif de créatifs passionnés par la création d'expériences digitales inoubliables. Nous travaillons avec des marques visionnaires pour transformer leurs ambitions en réalité.</p>
      <p>Notre approche combine stratégie profonde et exécution créative de haut niveau.</p>
      
      <div class="stats">
        <div class="stat">
          <div class="stat-number" data-target="150" data-suffix="+">0</div>
          <div class="stat-label" data-i18n="statProjects">Projets</div>
        </div>
        <div class="stat">
          <div class="stat-number" data-target="45" data-suffix="">0</div>
          <div class="stat-label" data-i18n="statTalents">Talents</div>
        </div>
        <div class="stat">
          <div class="stat-number" data-target="12" data-suffix=" ans">0</div>
          <div class="stat-label" data-i18n="statExperience">Expérience</div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services">
      <h2 data-i18n="services">Services</h2>
      <div class="services-list">
        <div class="service" onclick="openServiceModal('essential')">
          <div class="service-number">01</div>
          <div class="service-content">
            <h3>Création Essentielle</h3>
            <p>Publications Diagnostic rapide et actionnable pour identifier ce qui fonctionne et prioriser les actions : cessez d’avancer à l’aveugle, communiquez avec méthode. design de base. Une présence régulière et cohérente pour poser les bases d'une communication professionnelle.</p>
          </div>
        </div>
        <div class="service" onclick="openServiceModal('branding')">
          <div class="service-number">02</div>
          <div class="service-content">
            <h3>Création Avancée</h3>
            <p>Publications, identité visuelle Une identité propre et crédible dès le premier jour : logo, couleurs et mini-guide pratiques que vous pourrez utiliser tout de suite. cohérence. Un feed structuré et identifiable pour renforcer votre image de marque.</p>
          </div>
        </div>
        <div class="service" onclick="openServiceModal('premium')">
          <div class="service-number">03</div>
          <div class="service-content">
            <h3>Création Premium</h3>
            <p>Accompagnement éditorial complet. Une communication continue et professionnelle pour développer votre visibilité long terme.</p>
          </div>
        </div>
        <div class="service" onclick="openServiceModal('strategy')">
          <div class="service-number">04</div>
          <div class="service-content">
            <h3>Photographie de Marque</h3>
            <p>Shooting photo simple Une stratégie claire et un message mémorable : comprenez qui vous ciblez, pourquoi ils devraient vous choisir et comment le dire efficacement. efficace. Des photos authentiques et cohérentes pour vos réseaux et supports de communication.</p>
          </div>
        </div>
        <div class="service" onclick="openServiceModal('photography')">
          <div class="service-number">05</div>
          <div class="service-content">
            <h3>Stratégie & Positionnement</h3>
            <p>Clarté, cohérence et direction. Une stratégie claire pour savoir quoi dire, à qui et comment avant de produire du contenu.</p>
          </div>
        </div>
        <div class="service" onclick="openServiceModal('custom')">
          <div class="service-number">06</div>
          <div class="service-content">
            <h3>Formule Custom</h3>
            <p>Adaptée à vos besoins réels. Cette formule s.adapte précisément à vos objectifs, votre budget et votre rythme.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICE MODAL -->
    <div id="service-modal" class="service-modal">
      <div class="service-modal-content">
        <button class="service-modal-close" onclick="closeServiceModal()">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
        <div id="service-modal-body"></div>
      </div>
    </div>

    <!-- PROJECTS -->
    <section id="projects">
      <h2 data-i18n="work">Nos travaux</h2>
      <div class="projects-list">
        <div class="project" onclick="openProjectModal('techstart')">
          <img src="https://images.unsplash.com/photo-1611339555312-e607c04352fd?w=600&h=600&fit=crop" alt="Projet TechStart">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>TechStart Campaign</h3>
              <p>Production vidéo • Motion design</p>
            </div>
          </div>
        </div>
        <div class="project" onclick="openProjectModal('brandflow')">
          <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=600&h=600&fit=crop" alt="Projet BrandFlow">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>BrandFlow Identity</h3>
              <p>Branding • Design • Web</p>
            </div>
          </div>
        </div>
        <div class="project" onclick="openProjectModal('streamvibe')">
          <img src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=600&h=600&fit=crop" alt="Projet StreamVibe">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>StreamVibe Platform</h3>
              <p>UX Design • Development</p>
            </div>
          </div>
        </div>
        <div class="project" onclick="openProjectModal('visualabs')">
          <img src="https://images.unsplash.com/photo-1515378791036-0648a3e4d747?w=600&h=600&fit=crop" alt="Projet VisuaLabs">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>VisuaLabs Summit</h3>
              <p>Event video • Live streaming</p>
            </div>
          </div>
        </div>
        <div class="project" onclick="openProjectModal('neuraiai')">
          <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=600&h=600&fit=crop" alt="Projet NeuralAI">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>NeuralAI Campaign</h3>
              <p>Concept • Production</p>
            </div>
          </div>
        </div>
        <div class="project" onclick="openProjectModal('creativehub')">
          <img src="https://images.unsplash.com/photo-1460925895917-aeb19be489c7?w=600&h=600&fit=crop" alt="Projet CreativeHub">
          <div class="project-overlay">
            <div class="project-overlay-content">
              <h3>CreativeHub Analytics</h3>
              <p>Data visualization • Dashboard</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- PROJECT MODAL -->
    <div id="project-modal" class="project-modal">
      <div class="project-modal-content">
        <button class="project-modal-close" onclick="closeProjectModal()">
          <svg viewBox="0 0 24 24" fill="none">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
        <div id="project-modal-body"></div>
      </div>
    </div>

    <!-- CONTACT -->
    <section id="contact">
      <h2 data-i18n="contactTitle">Lançons votre projet</h2>
      <div class="contact-wrapper">
        <form class="contact-form" id="contact-form" onsubmit="handleSubmit(event)">
          <div class="form-group">
            <label for="name" data-i18n="nameLabel">Votre nom</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email" data-i18n="emailLabel">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
          <div class="form-group">
            <label for="message" data-i18n="messageLabel">Message</label>
            <textarea id="message" name="message" required></textarea>
          </div>
          <button type="submit" class="cta" data-i18n="sendBtn">Envoyer</button>
          <div id="form-status" style="font-size: 13px; color: var(--text-light); margin-top: 16px;"></div>
        </form>

        <div class="contact-info">
          <h3>Contact</h3>
