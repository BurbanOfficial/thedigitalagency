          'Suivi et recommandations'
        ]
      },
      'photography': {
        number: '04',
        title: 'Photographie de Marque',
        subtitle: 'Shooting photo simple & efficace',
        pitch: 'Des photos authentiques et cohérentes pour alimenter vos réseaux, votre site ou vos supports de communication.',
        description: 'Des photos authentiques et cohérentes pour alimenter vos réseaux, votre site ou vos supports de communication.',
        timeline: '1 journée + livraison sous 7 jours',
        budget: '150 – 300 €',
        deliverables: [
          '10 à 20 photos retouchées (selon formule)',
          'Fichiers HD + formats web',
          'Droits d\'utilisation inclus',
          'Pas de vidéo, ni de tournage'
        ],
        process: [
          'Brief visuel (ambiance, objectifs, usages)',
          'Prise de vue (produits, lieux, portraits simples)',
          'Sélection et retouches légères',
          'Livraison finale'
        ]
      },
      'strategy': {
        number: '05',
        title: 'Stratégie & Positionnement',
        subtitle: 'Clarté, cohérence et direction',
        pitch: 'Une stratégie claire pour savoir quoi dire, à qui et comment — avant de produire du contenu.',
        description: 'Une stratégie claire pour savoir quoi dire, à qui et comment — avant de produire du contenu.',
        timeline: '7–14 jours',
        budget: '200 – 450 €',
        deliverables: [
          'Positionnement de marque',
          'Ligne éditoriale claire',
          'Messages clés & ton de communication',
          'Recommandations de formats et canaux'
        ],
        process: [
          'Entretien stratégique',
          'Analyse de la cible et de la concurrence',
          'Définition du positionnement et du message',
          'Recommandations concrètes'
        ]
      },
      'custom': {
        number: '06',
        title: 'Formule Custom',
        subtitle: 'Adaptée à vos besoins réels',
        pitch: 'Chaque projet est différent : cette formule s\'adapte précisément à vos objectifs, votre budget et votre rythme.',
        description: 'Chaque projet est différent : cette formule s\'adapte précisément à vos objectifs, votre budget et votre rythme.',
        timeline: 'Variable',
        budget: 'Sur devis',
        deliverables: [
          'Définis ensemble selon le projet',
          'Devis clair et détaillé'
        ],
        process: [
          'Analyse du besoin',
          'Proposition personnalisée',
          'Validation du périmètre',
          'Production & suivi'
        ]
      }
    };

    function openServiceModal(serviceId) {
      const service = servicesData[serviceId];
      if (!service) return;

      let html = `
        <div class="service-modal-header">
          <div class="service-modal-number">${service.number}</div>
          <h2>${service.title}</h2>
        </div>
        
        <p class="service-modal-description">${service.description}</p>
        
        <div class="service-modal-details">
          <div class="detail-item">
            <strong>${t('timeline')}</strong>
            <p>${service.timeline}</p>
          </div>
          <div class="detail-item">
            <strong>${t('budget')}</strong>
            <p>${service.budget}</p>
          </div>
          <div class="detail-item">
            <strong>${t('process')}</strong>
            <p>${service.process.length} étapes</p>
          </div>
        </div>

        <div class="service-modal-benefits">
          <h3>${t('deliverables')}</h3>
          <ul class="benefits-list">
      `;

      service.deliverables.forEach(item => {
        html += `<li>${item}</li>`;
      });

      html += `
          </ul>
        </div>

        <div class="service-modal-benefits">
          <h3>${t('ourProcess')}</h3>
          <ul class="benefits-list">
      `;

      service.process.forEach(item => {
        html += `<li>${item}</li>`;
      });

      html += `
          </ul>
        </div>

        <div class="service-modal-cta">
          <button class="btn-primary" onclick="scrollToContact(); closeServiceModal();">${t('discuss')}</button>
          <button class="btn-secondary" onclick="closeServiceModal();">${t('close')}</button>
        </div>
      `;

      document.getElementById('service-modal-body').innerHTML = html;
      document.getElementById('service-modal').classList.add('active');
      // Scroll to top of modal content
      document.querySelector('.service-modal-content').scrollTop = 0;
      // Block background scroll
      document.body.classList.add('modal-open');
    }

    function closeServiceModal() {
      document.getElementById('service-modal').classList.remove('active');
      // Unblock background scroll
      document.body.classList.remove('modal-open');
    }

    // Fermer la modal en cliquant en dehors
    document.getElementById('service-modal').addEventListener('click', (e) => {
      if (e.target.id === 'service-modal') {
        closeServiceModal();
      }
    });

    function openQuiz() {
      const modal = document.getElementById('quiz-modal');
      modal.classList.add('active');
      currentQuestion = 0;
      quizAnswers = {};
      renderQuestion();
      // Block background scroll
      document.body.classList.add('modal-open');
    }

    function closeQuiz() {
      const modal = document.getElementById('quiz-modal');
      modal.classList.remove('active');
      // Unblock background scroll
      document.body.classList.remove('modal-open');
    }

    function renderQuestion() {
      const content = document.getElementById('quiz-content');
      const translatedQuizData = getTranslatedQuizData();
      const question = translatedQuizData[currentQuestion];
      const progress = ((currentQuestion + 1) / translatedQuizData.length) * 100;

      let html = `
        <div class="quiz-title">Questions sur vos besoins</div>
        <div class="quiz-subtitle">Question ${currentQuestion + 1}/${translatedQuizData.length}</div>
        <div class="quiz-progress">
          <div class="quiz-progress-bar" style="width: ${progress}%"></div>
        </div>
        <div class="quiz-question">
          <h3>${question.question}</h3>
          <div class="quiz-options">
      `;

      question.options.forEach((option, index) => {
        html += `
          <button class="quiz-option" onclick="selectOption('${option.category}', ${index})">
            ${option.text}
          </button>
        `;
      });

      html += `</div></div>`;

      content.innerHTML = html;
    }

    function getTranslatedQuizData() {
      return [
        {
          question: t('quiz_q1'),
          options: [
            { text: t('quiz_q1_o1'), category: "branding" },
            { text: t('quiz_q1_o2'), category: "video" },
            { text: t('quiz_q1_o3'), category: "digital" },
            { text: t('quiz_q1_o4'), category: "motion" }
          ]
        },
        {
          question: t('quiz_q2'),
          options: [
            { text: t('quiz_q2_o1'), category: "motion" },
            { text: t('quiz_q2_o2'), category: "branding" },
            { text: t('quiz_q2_o3'), category: "video" },
            { text: t('quiz_q2_o4'), category: "digital" }
          ]
        },
        {
          question: t('quiz_q3'),
          options: [
            { text: t('quiz_q3_o1'), category: "digital" },
            { text: t('quiz_q3_o2'), category: "video" },
            { text: t('quiz_q3_o3'), category: "branding" },
            { text: t('quiz_q3_o4'), category: "motion" }
          ]
        },
        {
          question: t('quiz_q4'),
          options: [
            { text: t('quiz_q4_o1'), category: "motion" },
            { text: t('quiz_q4_o2'), category: "branding" },
            { text: t('quiz_q4_o3'), category: "video" },
            { text: t('quiz_q4_o4'), category: "digital" }
          ]
        },
        {
          question: t('quiz_q5'),
          options: [
            { text: t('quiz_q5_o1'), category: "branding" },
            { text: t('quiz_q5_o2'), category: "motion" },
            { text: t('quiz_q5_o3'), category: "digital" },
            { text: t('quiz_q5_o4'), category: "video" }
          ]
        }
      ];
    }

    function selectOption(category, index) {
      quizAnswers[currentQuestion] = category;
      const translatedQuizData = getTranslatedQuizData();
      
      if (currentQuestion < translatedQuizData.length - 1) {
        currentQuestion++;
        renderQuestion();
      } else {
        showResult();
      }
    }

    function showResult() {
      // Compter les catégories les plus sélectionnées
      const counts = {};
      Object.values(quizAnswers).forEach(cat => {
        counts[cat] = (counts[cat] || 0) + 1;
      });

      const recommendedService = Object.keys(counts).reduce((a, b) => 
        counts[a] > counts[b] ? a : b
      );

      const service = serviceResults[recommendedService];
      const content = document.getElementById('quiz-content');

      let html = `
        <div class="quiz-result">
          <h2>${t('quiz_results')}</h2>
          <div class="quiz-result-service">${service.title}</div>
          <p class="quiz-result-desc">${service.description}</p>
          <div style="text-align: left; background: rgba(255, 255, 255, 0.02); padding: 20px; border-radius: 6px; margin-bottom: 24px; border: 1px solid rgba(255, 255, 255, 0.1);">
            <strong style="display: block; margin-bottom: 12px;">${t('discuss')} :</strong>
            <ul style="list-style: none; padding: 0;">
      `;

      service.benefits.forEach(benefit => {
        html += `<li style="margin-bottom: 8px; padding-left: 20px; position: relative;">
          <span style="position: absolute; left: 0; color: var(--accent);">✓</span>
          ${benefit}
        </li>`;
      });

      html += `
            </ul>
          </div>
          <div class="quiz-buttons">
            <button class="quiz-btn quiz-btn-primary" onclick="scrollToContact(); closeQuiz();">
              ${t('discuss')}
            </button>
            <button class="quiz-btn quiz-btn-secondary" onclick="openQuiz();">
              Recommencer le quiz
            </button>
          </div>
        </div>
      `;

      content.innerHTML = html;
    }

    function scrollToContact() {
      document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
    }

    // Fermer la modal en cliquant en dehors
    document.getElementById('quiz-modal').addEventListener('click', (e) => {
      if (e.target.id === 'quiz-modal') {
        closeQuiz();
      }
    });

    // === APPLY TRANSLATIONS ===
    function applyTranslations() {
      document.querySelectorAll('[data-i18n]').forEach(element => {
        const key = element.getAttribute('data-i18n');
        element.textContent = t(key);
      });
    }

    // Apply translations on page load
    applyTranslations();
    updateLanguageButton();

    // Language toggle
    const langToggle = document.getElementById('lang-toggle');
    langToggle.addEventListener('click', () => {
      userLanguage = userLanguage === 'fr' ? 'en' : 'fr';
      localStorage.setItem('language', userLanguage);
      document.documentElement.setAttribute('lang', userLanguage);
      applyTranslations();
      updateLanguageButton();
    });

    function updateLanguageButton() {
      const langBtn = document.getElementById('lang-toggle');
      langBtn.textContent = userLanguage === 'fr' ? 'EN' : 'FR';
    }

    // Listen for language changes (if implemented)
    window.addEventListener('storage', (e) => {
      if (e.key === 'language') {
        userLanguage = e.newValue;
        document.documentElement.setAttribute('lang', userLanguage);
        applyTranslations();
        updateLanguageButton();
      }
    });
  </script>
</body>
</html>