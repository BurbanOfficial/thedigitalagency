    function openProjectModal(projectId) {
      const project = projectsData[projectId];
      if (!project) return;

      let html = `
        <img src="${project.image}" alt="${project.title}" class="project-modal-image">
        <div class="project-modal-body">
          <div class="project-modal-header">
            <div class="project-modal-header-content">
              <h2>${project.title}</h2>
            </div>
            <div class="project-modal-header-meta">
              <div>${project.year}</div>
            </div>
          </div>

          <p class="project-modal-description">${project.description}</p>

          <div class="project-modal-grid">
            <div class="project-detail-item">
              <strong>${t('client')}</strong>
              <p>${project.client}</p>
            </div>
            <div class="project-detail-item">
              <strong>${t('duration')}</strong>
              <p>${project.duration}</p>
            </div>
            <div class="project-detail-item">
              <strong>${t('budget')}</strong>
              <p>${project.budget}</p>
            </div>
          </div>

          <div class="project-modal-section">
            <h3>${t('servicesProvided')}</h3>
            <div class="project-modal-services">
      `;

      project.services.forEach(service => {
        html += `<span class="project-service-tag">${service}</span>`;
      });

      html += `
            </div>
          </div>

          <div class="project-modal-section">
            <h3>${t('resultsAchieved')}</h3>
            <ul class="benefits-list">
      `;

      project.results.forEach(result => {
        html += `<li>${result}</li>`;
      });

      html += `
            </ul>
          </div>

          <div class="project-modal-cta">
            <a href="${project.url}" target="_blank" rel="noopener noreferrer" class="btn-primary">${t('visitWebsite')}</a>
            <button class="btn-secondary" onclick="closeProjectModal();">${t('close')}</button>
          </div>
        </div>
      `;

      document.getElementById('project-modal-body').innerHTML = html;
      document.getElementById('project-modal').classList.add('active');
      // Scroll to top of modal content
      document.querySelector('.project-modal-content').scrollTop = 0;
      // Block background scroll
      document.body.classList.add('modal-open');
    }

    function closeProjectModal() {
      document.getElementById('project-modal').classList.remove('active');
      // Unblock background scroll
      document.body.classList.remove('modal-open');
    }

    // Fermer la modal en cliquant en dehors
